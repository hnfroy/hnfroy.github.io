---
---

<section id="contact" class="py-32 px-6 md:px-16 border-t border-white/5">
  <div class="max-w-5xl mx-auto">
    <div class="grid md:grid-cols-2 gap-16 items-start">
      <div>
        <div class="w-fit">
          <p class="font-mono text-[#C8F135] text-xs tracking-[0.3em] uppercase mb-4">
            <span class="typing-text">Let's Work Together</span>
          </p>
        </div>

        <h2 class="text-4xl md:text-5xl font-bold mb-6 section-heading">
          Got a project<br />in mind?
        </h2>

        <p class="text-white/50 text-base leading-relaxed mb-10 anim-item">
          I'm always open to discussing new opportunities, collaborations, or just chatting about design.
        </p>

        <div class="space-y-4 anim-item">
          <a href="mailto:hnfroy@gmail.com" class="flex items-center gap-3 text-white/60 hover:text-[#C8F135] transition-colors text-sm group">
            <span class="font-mono text-[#C8F135]/40 text-xs w-6">01</span>
            hnfroy@gmail.com
            <span class="opacity-0 group-hover:opacity-100 transition-opacity">→</span>
          </a>
          <a href="https://linkedin.com/in/hanif-royyan" target="_blank" class="flex items-center gap-3 text-white/60 hover:text-[#C8F135] transition-colors text-sm group">
            <span class="font-mono text-[#C8F135]/40 text-xs w-6">02</span>
            LinkedIn
            <span class="opacity-0 group-hover:opacity-100 transition-opacity">→</span>
          </a>
        </div>
      </div>

      <!-- Form box -->
      <div class="border border-white/5 p-8 anim-item">
        <div class="space-y-6">
          <div>
            <label class="font-mono text-white/30 text-xs tracking-widest uppercase block mb-2">Name</label>
            <input type="text" placeholder="Your name" class="w-full bg-white/5 border border-white/10 text-white px-4 py-3 text-sm focus:outline-none focus:border-[#C8F135] transition-colors placeholder:text-white/20" />
          </div>
          <div>
            <label class="font-mono text-white/30 text-xs tracking-widest uppercase block mb-2">Email</label>
            <input type="email" placeholder="your@email.com" class="w-full bg-white/5 border border-white/10 text-white px-4 py-3 text-sm focus:outline-none focus:border-[#C8F135] transition-colors placeholder:text-white/20" />
          </div>
          <div>
            <label class="font-mono text-white/30 text-xs tracking-widest uppercase block mb-2">Message</label>
            <textarea rows="4" placeholder="Tell me about your project..." class="w-full bg-white/5 border border-white/10 text-white px-4 py-3 text-sm focus:outline-none focus:border-[#C8F135] transition-colors placeholder:text-white/20 resize-none"></textarea>
          </div>
          <button class="w-full bg-[#C8F135] text-[#0A0A0A] font-semibold py-4 text-sm tracking-wide hover:bg-white transition-colors duration-200">
            Send Message →
          </button>
        </div>
      </div>
    </div>

    <!-- Footer -->
    <div class="mt-24 pt-8 border-t border-white/5 flex items-center justify-between flex-wrap gap-4 anim-item">
      <p class="font-mono text-white/20 text-xs">© 2025 Hanif Roy. All rights reserved.</p>
      <p class="font-mono text-white/20 text-xs">Designed & Built with Astro + Tailwind</p>
    </div>
  </div>
</section>