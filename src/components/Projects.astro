---
const projects = [
  {
    num: "01",
    title: "Gerakan Pemuda Natuna",
    tags: ["Community", "Web Platform"],
    desc: "Contributed as a UI/UX Designer and Team Lead for the second phase of GPNatuna WebApp, focusing on internal system modules, workflow optimization, usability improvements, and interface consistency.",
    role: "Designer & Developer",
    year: "2025",
    demo: "https://gpnatuna.org/",
    image: "", // ← taruh URL gambar di sini nanti
    gradient: "from-[#1a3a2a] via-[#0d1f16] to-[#050505]",
    accent: "#2d6b47",
  },
  {
    num: "02",
    title: "KI Komunal Indonesia",
    tags: ["Goverment Platform", "Web App Design"],
    desc: "Contributed as a UI/UX Designer and Frontend Developer for KIKomunal Indonesia, designing intuitive user interfaces and implementing responsive frontend solutions using React and TypeScript.",
    role: "UI/UX Designer & Developer",
    year: "2024",
    demo: "https://kikomunal-indonesia.dgip.go.id/home",
    image: "",
    gradient: "from-[#1a2a3a] via-[#0d1620] to-[#050505]",
    accent: "#2d4f6b",
  },
  {
    num: "03",
    title: "Pengaduan DJKI",
    tags: ["Gov Platform", "UX Research"],
    desc: "Contributed as a UI/UX Designer and Frontend Developer for Pengaduan KI, designing user-centered interfaces and developing responsive web applications using React, TypeScript, Tailwind CSS, and Framer Motion.",
    role: "UI/UX Designer & Developer",
    year: "2024",
    demo: "https://pengaduan.dgip.go.id/home",
    image: "",
    gradient: "from-[#2a1a3a] via-[#180d20] to-[#050505]",
    accent: "#5a2d6b",
  },
  {
    num: "04",
    title: "Shaftech Company Profile",
    tags: ["Company Profile", "Web Design"],
    desc: "Designed and developed the official SHAF Tech website using Astro and GSAP, creating a modern, high-performance, and engaging digital experience.",
    role: "Designer & Developer",
    year: "2025",
    demo: "https://shaftech.vercel.app/",
    image: "",
    gradient: "from-[#1A1F2A] via-[#080C18] to-[#050505]",
    accent: "#6b6b2d",
  },
  {
    num: "05",
    title: "SHAF POS System",
    tags: ["Dashboard", "POS"],
    desc: "Point-of-sale system to manage, monitor stock and generate business reports in real time.",
    role: "Designer & Developer",
    year: "2025",
    demo: "https://shaf-pos.vercel.app/",
    image: "",
    gradient: "from-[#2a1a1a] via-[#200d0d] to-[#050505]",
    accent: "#6b2d2d",
  },
];
---

<section id="projects" class="py-32 px-6 md:px-16 border-t border-white/5">
  <div class="max-w-6xl mx-auto">

    <div class="flex items-end justify-between mb-16 flex-wrap gap-6">
      <div>
        <div class="w-fit">
          <p class="font-mono text-[#C8F135] text-xs tracking-[0.3em] uppercase mb-4">
            <span class="typing-text">Selected Work</span>
          </p>
        </div>
        <h2 class="text-4xl md:text-5xl font-bold tracking-tight section-heading">
          Featured Projects
        </h2>
      </div>
      <p class="text-white/30 font-mono text-xs">{projects.length} projects</p>
    </div>

    <div class="projects-grid grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      {projects.map((project, index) => (
        <div
          class={`project-card group relative overflow-hidden rounded-2xl border border-white/5 bg-white/[0.02] flex flex-col cursor-pointer hover:border-[#C8F135]/20 transition-colors duration-300 ${index === 0 ? 'md:col-span-2 lg:col-span-2' : ''}`}
          data-index={index}
          data-project={JSON.stringify(project)}
          onclick="openModal(this)"
        >
          <!-- Image / Gradient placeholder -->
          <div class="relative overflow-hidden aspect-video">

            {project.image ? (
              /* Jika URL gambar sudah diisi */
              <>
                <div class="absolute inset-0 bg-gradient-to-t from-[#050505] via-transparent to-transparent z-10" />
                <img
                  src={project.image}
                  alt={project.title}
                  loading="lazy"
                  class="w-full h-full object-cover scale-100 group-hover:scale-105 transition-transform duration-700 ease-out grayscale group-hover:grayscale-0"
                />
              </>
            ) : (
              /* Gradient placeholder — miring kiri bawah → kanan atas */
              <div class={`absolute inset-0 bg-gradient-to-tr ${project.gradient} transition-opacity duration-500`}>
                {/* Grid lines dekoratif */}
                <div class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.03)_1px,transparent_1px)] bg-[size:32px_32px]" />
                {/* Accent glow pojok kiri bawah */}
                <div
                  class="absolute bottom-0 left-0 w-48 h-48 rounded-full opacity-20 group-hover:opacity-40 transition-opacity duration-500 blur-3xl"
                  style={`background: ${project.accent};`}
                />
                {/* Project title watermark */}
                <div class="absolute inset-0 flex items-center justify-center">
                  <p class="font-mono text-white/5 text-6xl font-bold tracking-tighter select-none">
                    {project.num}
                  </p>
                </div>
              </div>
            )}

            <!-- Overlay gradient bottom -->
            <div class="absolute inset-0 bg-gradient-to-t from-[#050505]/80 via-transparent to-transparent z-10 pointer-events-none" />

            <!-- Number badge -->
            <span class="absolute top-4 left-4 z-20 font-mono text-xs text-white/40 border border-white/10 px-3 py-1 rounded-full bg-black/40 backdrop-blur-sm">
              {project.num}
            </span>

            <!-- Arrow -->
            <div class="absolute top-4 right-4 z-20 w-9 h-9 rounded-full border border-white/10 flex items-center justify-center bg-black/40 backdrop-blur-sm text-white text-sm opacity-0 -translate-y-2 group-hover:opacity-100 group-hover:translate-y-0 group-hover:bg-[#C8F135] group-hover:text-black group-hover:border-transparent transition-all duration-300">
              ↗
            </div>
          </div>

          <!-- Content -->
          <div class="p-5 flex flex-col gap-3 flex-1">
            <div class="flex flex-wrap gap-2">
              {project.tags.map(tag => (
                <span class="text-[10px] font-mono border border-white/10 text-white/40 px-2.5 py-1 rounded-full">{tag}</span>
              ))}
            </div>
            <h3 class="text-lg font-semibold text-white group-hover:text-[#C8F135] transition-colors duration-300 leading-snug">
              {project.title}
            </h3>
            <p class="text-white/40 text-sm leading-relaxed flex-1">{project.desc}</p>
            <div class="pt-3 border-t border-white/5 flex items-center justify-between">
              <span class="text-white/20 group-hover:text-[#C8F135] text-xs font-mono transition-colors duration-300">
                View Detail →
              </span>
              <span class="font-mono text-white/20 text-xs">{project.year}</span>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Modal (sama seperti sebelumnya) -->
<div id="project-modal" class="fixed inset-0 z-[100] flex items-center justify-center p-4 opacity-0 pointer-events-none transition-opacity duration-300">
  <div class="absolute inset-0 bg-black/80 backdrop-blur-sm" onclick="closeModal()"></div>
  <div id="modal-box" class="relative z-10 bg-[#0F0F0F] border border-white/10 rounded-2xl w-full max-w-2xl max-h-[90vh] overflow-y-auto translate-y-6 transition-transform duration-300">
    <div class="relative aspect-video overflow-hidden rounded-t-2xl">
      <div class="absolute inset-0 bg-gradient-to-t from-[#0F0F0F] via-transparent to-transparent z-10" />
      <img id="modal-image" src="" alt="" class="w-full h-full object-cover" />
      <div id="modal-gradient" class="absolute inset-0 hidden"></div>
      <button onclick="closeModal()" class="absolute top-4 right-4 z-20 w-9 h-9 rounded-full bg-black/60 backdrop-blur-sm border border-white/10 text-white/60 hover:text-white hover:border-white/30 transition-all flex items-center justify-center text-sm">✕</button>
      <span id="modal-num" class="absolute top-4 left-4 z-20 font-mono text-xs text-white/40 border border-white/10 px-3 py-1 rounded-full bg-black/40 backdrop-blur-sm"></span>
    </div>
    <div class="p-6 md:p-8 space-y-5">
      <div id="modal-tags" class="flex flex-wrap gap-2"></div>
      <h3 id="modal-title" class="text-2xl md:text-3xl font-bold text-white"></h3>
      <div class="flex gap-6 flex-wrap">
        <div>
          <p class="font-mono text-white/25 text-xs tracking-widest uppercase mb-1">Role</p>
          <p id="modal-role" class="text-white/70 text-sm"></p>
        </div>
        <div>
          <p class="font-mono text-white/25 text-xs tracking-widest uppercase mb-1">Year</p>
          <p id="modal-year" class="text-white/70 text-sm"></p>
        </div>
      </div>
      <p id="modal-desc" class="text-white/60 text-sm leading-relaxed border-t border-white/5 pt-5"></p>
      <div class="flex gap-3 flex-wrap pt-2">
        <a id="modal-demo-btn" href="#" target="_blank"
          class="hidden items-center gap-2 bg-[#C8F135] text-[#0A0A0A] font-semibold px-5 py-3 text-sm rounded-xl hover:bg-white transition-colors duration-200">
          View Demo ↗
        </a>
        <button onclick="closeModal()"
          class="flex items-center gap-2 border border-white/10 text-white/50 text-sm px-5 py-3 rounded-xl hover:border-white/30 hover:text-white transition-all duration-200">
          Close
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  // Card entrance
  const cards = document.querySelectorAll('.project-card');
  const entranceObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const el = entry.target as HTMLElement;
        setTimeout(() => {
          el.style.opacity = '1';
          el.style.transform = 'translateY(0)';
        }, Number(el.dataset.index) * 80);
        entranceObserver.unobserve(el);
      }
    });
  }, { threshold: 0.1 });

  cards.forEach(card => {
    (card as HTMLElement).style.cssText = 'opacity:0; transform:translateY(32px); transition: opacity 0.6s ease, transform 0.6s ease;';
    entranceObserver.observe(card);
  });

  // Modal
  const modal = document.getElementById('project-modal')!;
  const modalBox = document.getElementById('modal-box')!;

  (window as any).openModal = function(el: HTMLElement) {
    const p = JSON.parse(el.dataset.project!);

    const modalImg = document.getElementById('modal-image') as HTMLImageElement;
    const modalGrad = document.getElementById('modal-gradient')!;

    if (p.image) {
      modalImg.src = p.image;
      modalImg.classList.remove('hidden');
      modalGrad.classList.add('hidden');
    } else {
      modalImg.src = '';
      modalImg.classList.add('hidden');
      modalGrad.classList.remove('hidden');
      modalGrad.className = `absolute inset-0 bg-gradient-to-tr ${p.gradient}`;
    }

    document.getElementById('modal-num')!.textContent = p.num;
    document.getElementById('modal-title')!.textContent = p.title;
    document.getElementById('modal-desc')!.textContent = p.desc;
    document.getElementById('modal-role')!.textContent = p.role;
    document.getElementById('modal-year')!.textContent = p.year;

    document.getElementById('modal-tags')!.innerHTML = p.tags.map((t: string) =>
      `<span class="text-[10px] font-mono border border-white/10 text-white/40 px-2.5 py-1 rounded-full">${t}</span>`
    ).join('');

    const demoBtn = document.getElementById('modal-demo-btn')!;
    if (p.demo) {
      demoBtn.setAttribute('href', p.demo);
      demoBtn.classList.remove('hidden');
      demoBtn.classList.add('flex');
    } else {
      demoBtn.classList.add('hidden');
      demoBtn.classList.remove('flex');
    }

    modal.classList.remove('pointer-events-none');
    requestAnimationFrame(() => {
      modal.style.opacity = '1';
      modalBox.style.transform = 'translateY(0)';
    });
    document.body.style.overflow = 'hidden';
  };

  (window as any).closeModal = function() {
    modal.style.opacity = '0';
    modalBox.style.transform = 'translateY(24px)';
    setTimeout(() => {
      modal.classList.add('pointer-events-none');
      document.body.style.overflow = '';
    }, 300);
  };

  document.addEventListener('keydown', e => {
    if (e.key === 'Escape') (window as any).closeModal();
  });
</script>

<style>
  #modal-box { transform: translateY(24px); }
</style>